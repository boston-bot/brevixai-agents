APP_ENV=local
BREVIX_AGENT_SERVICE_KEY=local-dev-key
BREVIX_LARAVEL_BASE_URL=http://localhost:8000
BREVIX_LARAVEL_AGENT_TOOL_KEY=local-dev-key
HTTP_TIMEOUT_SECONDS=20
LOG_LEVEL=info
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=brevix-ai
OPENAI_API_KEY=
BREVIX_AGENT_GRAPH_VERSION=phase-2-observability-v1
BREVIX_AGENT_FEATURE_FLAGS=
BREVIX_AGENT_MODEL_PROVIDER=deterministic
BREVIX_AGENT_MODEL_NAME=deterministic-risk-v1
BREVIX_AGENT_MODEL_TIMEOUT_SECONDS=30

# ──────────────────────────────────────────────
# Orchestrator deployment settings
# ──────────────────────────────────────────────

# Bearer token that callers must supply to reach /agent/run.
# Required in production — the service refuses to start when this is empty.
# Alias for BREVIX_AGENT_SERVICE_KEY; set whichever your deploy platform
# injects from Secrets Manager / Parameter Store.
ORCHESTRATOR_API_TOKEN=

# Comma-separated list of allowed CORS origins.
# Required in production — the service will refuse to start if this is unset
# and APP_ENV=production|prod.  In local/dev/test it defaults to ["*"].
# Example: https://app.brevix.ai,https://admin.brevix.ai
ORCHESTRATOR_ALLOWED_ORIGINS=

# Comma-separated list of action types that require human approval before
# execution.  Changing this value does not bypass the hard-coded gate in
# graph.py; it documents the default and is reserved for future config-driven
# extension of the approval set.
ORCHESTRATOR_APPROVAL_REQUIRED_TOOLS=draft_case,draft_email,send_email,flag_transaction,finalize_case,update_case

# Checkpointer backend for LangGraph state persistence.
# Leave empty (default) to use the in-memory checkpointer.
# Set to "postgres" to enable Postgres-backed persistence — requires
# psycopg2-binary (sync) or psycopg (async) to be installed:
#   pip install -e ".[postgres]"   (once that extras group is added)
ORCHESTRATOR_CHECKPOINTER=

# Postgres connection string.  Required when ORCHESTRATOR_CHECKPOINTER=postgres.
# Example: postgresql+asyncpg://user:pass@localhost:5432/brevixai
DATABASE_URL=
